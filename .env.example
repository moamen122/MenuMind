# Database (PostgreSQL / Supabase)
# Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.utoabuwodxpavrndtzsy.supabase.co:5432/postgres
# Local PostgreSQL: postgresql://user:password@localhost:5432/menumind
DATABASE_URL="postgresql://postgres:password@db.utoabuwodxpavrndtzsy.supabase.co:5432/postgres"

# Server
PORT=3000
NODE_ENV=development

# JWT (auth - placeholder)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI / external services (placeholder)
OPENAI_API_KEY=

# Use free mock AI for menu extraction (no API key). Good for testing.
# Set to true to skip OpenAI and parse menu text with simple rules.
# USE_MOCK_AI=true

# Menu extraction: translate Arabic item names for image search (optional).
# LIBRETRANSLATE_URL=https://libretranslate.com

# Menu extraction: attach Pexels image URL to each item (optional). Get key: https://www.pexels.com/api/
# PEXELS_API_KEY=

# QR menu: base URL for menu view (e.g. frontend app). Used for QR code target.
# QR_MENU_BASE_URL=https://app.menumind.com
# Or use FRONTEND_URL if you prefer a single frontend base URL.

# CORS: required for frontend. Add your deployed frontend URL for production.
# CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://menu-smart-analyzer.vercel.app

# Frontend / QR base URL (for QR codes and redirects). Use deployed frontend in production.
# FRONTEND_URL=https://menu-smart-analyzer.vercel.app
# QR_MENU_BASE_URL=https://menu-smart-analyzer.vercel.app

# Optional: Rate limiting
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100
